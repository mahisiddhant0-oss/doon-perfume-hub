# ============================================
#   DOON PERFUME HUB — Backend Environment (Template)
# ============================================

# --- Server ---
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-frontend-domain.com

# --- MongoDB ---
# Production MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/doonperfumehub

# --- JWT Authentication ---
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRE=30d

# --- Razorpay (Payments) ---
# Get these from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# --- Razorpay Webhooks (Reliability) ---
# Create a webhook in Razorpay Dashboard for 'payment.captured'
# The secret you set there should be placed here.
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# --- Delhivery (Logistics) ---
# Get your Token from: https://www.delhivery.com/support/api
DELHIVERY_TOKEN=your_delhivery_api_token_here
DELHIVERY_ENVIRONMENT=production
# The registered pickup location name in your Delhivery dashboard
DELHIVERY_PICKUP_LOCATION=DOON_PERFUME_HUB_MAIN

# --- Email Notifications (Nodemailer) ---
# Use SMTP settings for Gmail, Outlook, or a service like SendGrid
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_EMAIL="DOON PERFUME HUB" <noreply@yourdomain.com>
# The email address that will receive new order alerts
ADMIN_EMAIL=admin@yourdomain.com

# --- SMS Notifications (Twilio) ---
# Get these from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# --- Firebase (Storage/Auth) ---
# Path to your Firebase service account JSON file
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-service-account.json
